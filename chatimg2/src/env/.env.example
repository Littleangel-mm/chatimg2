# ChatImg2 环境变量模板
# 复制为 .env 后填入真实值：cp .env.example .env

# API Configuration
API_KEY=sk-your-api-key-here
API_URL=https://www.maitokens.com
# 需在令牌管理选择含生图的分组（如 sora / image）
API_MODEL_TEXT2IMG=gpt-image-2
API_MODEL_IMG2IMG=gpt-image-2

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatimg2
DB_USER=postgres
DB_PASSWORD=your-db-password

# 灵感画廊爬虫（本机直连不了 img2.ai 时用代理）
INSPIRATION_DOWNLOAD_IMAGES=true
INSPIRATION_PROXY_ENABLED=false
INSPIRATION_PROXY_TYPE=SOCKS
INSPIRATION_PROXY_HOST=127.0.0.1
INSPIRATION_PROXY_PORT=1080
# 定时自动爬取（每天凌晨 00:00）
INSPIRATION_SCHEDULE_ENABLED=true
INSPIRATION_SCHEDULE_CRON=0 0 0 * * *
INSPIRATION_SCHEDULE_ZONE=Asia/Shanghai
